[user]
    name = lantzops
    email = lantz.mitch@gmail.com

[core]
    editor = nvim
    autocrlf = input
    pager = less -R

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[diff]
    colorMoved = default

[merge]
    conflictstyle = diff3

[color]
    ui = auto

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate -20
    last = log -1 HEAD
    unstage = reset HEAD --
    amend = commit --amend --no-edit
